{
  "name": "sharehouse-work",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack --hostname localhost --port 3000",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "next lint",
    "test": "node --test --experimental-strip-types \"src/**/*.test.ts\"",
    "db:seed": "node --experimental-strip-types scripts/seed-firestore.ts",
    "db:seed:reset": "node --experimental-strip-types scripts/seed-firestore.ts --reset",
    "emulators:start": "firebase emulators:start --project demo-sharehouse-work",
    "emulators:start:import": "firebase emulators:start --project demo-sharehouse-work --import=.firebase-data --export-on-exit=.firebase-data"
  },
  "dependencies": {
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "lucide-react": "^0.575.0",
    "next": "^16.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.1.7",
    "firebase-tools": "^15.8.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
